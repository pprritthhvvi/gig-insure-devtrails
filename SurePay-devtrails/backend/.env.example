# Database
DATABASE_URL=postgresql://gigguard:gigguard_dev_password@localhost:5432/gigguard_db

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://gigguard:gigguard_dev_password@localhost:5672//

# Environment
ENV=development
DEBUG=true

# JWT
JWT_SECRET=dev_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys and External Services

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# AWS S3 (Document Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=gigguard-dev
AWS_REGION=us-east-1

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Feature Flags
ENABLE_FRAUD_DETECTION=true
ENABLE_AUTO_PAYOUT=true
ENABLE_CLAIMS_AUTO_TRIGGER=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@gigguard.local
ADMIN_PASSWORD=change_this_password
